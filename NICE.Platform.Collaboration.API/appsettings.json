{
  // ══════════════════════════════════════════════════════════════════════════
  // NICE Platform — Standalone Recording API
  // appsettings.json  (Production / shared baseline)
  //
  // Sections:
  //   1. Logging
  //   2. Database
  //   3. Feature flags
  //   4. JWT (token signing)
  //   5. Auth validation
  //   6. Local file storage
  //   7. WebRTC / ICE
  //   8. Applications (per-app config)
  //   9. [PHASE 2] Azure SignalR  ← flip UseAzureSignalR=true here when ready
  // ══════════════════════════════════════════════════════════════════════════

  // ── 1. Logging ─────────────────────────────────────────────────────────────
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                              "Warning",
        "Microsoft.AspNetCore":                   "Warning",
        "Microsoft.EntityFrameworkCore":          "Warning",
        "Microsoft.AspNetCore.SignalR":           "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },

  // ── 2. Database ────────────────────────────────────────────────────────────
  // SQL Server — holds all 16 tables (6 active, 10 reserved for future use).
  // Override in appsettings.Development.json for local dev.
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=NICEStandaloneRecording;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  // ── Monitor console ────────────────────────────────────────────────────────
  // Base URL of the standalone Monitor Blazor app. Used to build the secure
  // launch URL returned by POST /api/v1/collaboration/monitor/handoff
  // (…/launch?code=<one-time-code>). No trailing slash required.
  "Monitor": {
    "BaseUrl": "http://localhost:5200"
  },

  // ── 3. Feature flags ───────────────────────────────────────────────────────
  // All flags default to OFF for the initial standalone release.
  // See Section 9 (Azure SignalR) before setting UseAzureSignalR=true.
  "FeatureFlags": {
    "UseAzureSignalR": false,   // → true once Azure SignalR connection string is set (Section 9)
    "UseAzureBlob":    false,   // → true when Azure Blob Storage replaces local disk
    "UseCustomTurn":   false,   // → true to use your own TURN server instead of Google STUN
    "UseRealBot":      false,   // always false in standalone (NoOpBotService registered)
    "UseReadiAuth":    false    // → true to make READI the default non-demo staff auth.
                                //   A per-app StaffAuthProvider (Section 8) still overrides this.
                                //   Requires AuthValidation:Endpoints:ReadiValidateUrl (Section 5).
  },

  // ── 4. JWT (token signing) ─────────────────────────────────────────────────
  // The Key here MUST exactly match AuthValidation:LocalJwt:Secret below.
  // Used by: JwtTokenService (mint), Program.cs JwtBearerOptions (validate).
  "Jwt": {
    "Key":                   "NICE-StandaloneRecording-LocalJwt-Secret-ChangeInProd-2024!",
    "Issuer":                "NICE.StandaloneRecording.Local",
    "Audience":              "NICE.StandaloneRecording.Api",
    "ExpiryMinutes":         480,
    "ExpiryMinutesExternal": 480
  },

  // ── 5. Auth validation ─────────────────────────────────────────────────────
  // Standalone supports READI (production / non-demo), LOCAL_JWT and ANON.
  //   • UseMock=true  → all providers return the configured Mock.* response (demo).
  //   • READI         → calls Endpoints.ReadiValidateUrl with the caller's AuthToken.
  // Mint a LOCAL_JWT token: POST /api/v1/demo/mint-token?name=John+Smith&role=StandAlone
  "AuthValidation": {
    "UseMock": false,
    "Endpoints": {
      // Required when READI is the active staff provider (UseMock=false).
      "ReadiValidateUrl": "https://readi.example.com/api/validate"
    },
    "Mock": {
      // Returned for READI logins while UseMock=true (demo). IsValid=false simulates rejection.
      "Readi": {
        "IsValid":   true,
        "UserId":    "mock-readi-user",
        "Email":     "mock@readi.example.com",
        "FirstName": "Mock",
        "LastName":  "Readi"
      }
    },
    "LocalJwt": {
      "Secret":         "NICE-StandaloneRecording-LocalJwt-Secret-ChangeInProd-2024!",
      "Issuer":         "NICE.StandaloneRecording.Local",
      "Audience":       "NICE.StandaloneRecording.Api",
      "ValidateExpiry": true
    }
  },

  // ── 6. Local file storage ──────────────────────────────────────────────────
  // Where recorded .mp4 files and attachments are saved on the server.
  // Recordings are organised into daily subfolders: RecordingsPath\yyyy-MM-dd\
  // Override in appsettings.Development.json for local paths.
  // Switch to UseAzureBlob=true (Section 3) when Azure Blob is provisioned.
  //
  // After each recording the server applies a pure-C# MP4 fix-up so the file
  // plays in Windows Media Player: fragmented MP4 (MediaRecorder output) is
  // de-fragmented into a progressive MP4, and already-progressive files get a
  // moov fast-start. No external tools or re-encoding are involved.
  "LocalStorage": {
    "RecordingsPath":  "C:\\Readi\\Recordings",
    "AttachmentsPath": "C:\\Readi\\Attachments"
  },

  // ── 7. WebRTC / ICE servers ────────────────────────────────────────────────
  // Default: Google public STUN servers (free, no credentials needed).
  // For cross-NAT reliability in production, provision a TURN server,
  // set UseCustomTurn=true and fill in TurnServer below.
  "IceServers": {
    "GoogleStun": [
      "stun:stun.l.google.com:19302",
      "stun:stun1.l.google.com:19302"
    ],
    "TurnServer": {
      "Urls":       [ "turn:your-turn-server.com:3478" ],
      "Username":   "REPLACE_WITH_TURN_USERNAME",
      "Credential": "REPLACE_WITH_TURN_CREDENTIAL"
    }
  },

  // ── 8. Applications ────────────────────────────────────────────────────────
  // Per-app configuration read by JsonApplicationConfigProvider.
  // Add more apps here as the standalone package is adopted by other products.
  //
  // StaffAuthProvider (READI | LOCAL_JWT | ANON) is the per-application OVERRIDE
  // for staff (non-External) logins and always wins when set. To use the global
  // READI default instead, set FeatureFlags:UseReadiAuth=true (Section 3) and
  // remove the StaffAuthProvider line below (or set it to READI).
  "Applications": {
    "Readi": {
      "StaffAuthProvider":      "LOCAL_JWT",
      "ExternalAuthProvider":   "ANON",
      "StandAlone": {
        "AutoRecordScreen":       false,
        "SupervisorCanWatchLive": true
      }
    }
  },

  // AuthProviders: legacy MultiProviderJwtAuthService section — unused by READI/LOCAL_JWT/ANON.
  "AuthProviders": {},

  // ── 9. [PHASE 2] Azure SignalR ─────────────────────────────────────────────
  // When you are ready to switch from self-hosted SignalR to Azure SignalR:
  //
  //   Step 1 — Provision an Azure SignalR Service (Standard tier, Serverless or Default mode).
  //   Step 2 — Paste the connection string from Azure portal below.
  //   Step 3 — Install NuGet:  dotnet add NICE.Platform.Collaboration.API package Microsoft.Azure.SignalR
  //   Step 4 — In Program.cs, change:
  //              builder.Services.AddSignalR(...)
  //            to:
  //              builder.Services.AddSignalR(...).AddAzureSignalR(builder.Configuration["Azure:SignalR:ConnectionString"]);
  //   Step 5 — Set FeatureFlags:UseAzureSignalR = true in this file.
  //
  // No code changes needed in hubs or clients — SignalR JS and .NET clients
  // connect to the same /hubs/v1/... routes; Azure SignalR transparently
  // proxies the WebSocket connections.
  "Azure": {
    "SignalR": {
      "ConnectionString": "REPLACE_WITH_AZURE_SIGNALR_CONNECTION_STRING"
    }
  }
}
