{
  // ══════════════════════════════════════════════════════════════════════════
  // NICE Platform — Standalone Recording API
  // appsettings.Development.json  (local dev overrides only)
  //
  // This file is NOT deployed to production.
  // It overrides appsettings.json for DOTNET_ENVIRONMENT=Development.
  // ══════════════════════════════════════════════════════════════════════════

  // ── Logging: verbose for local debugging ──────────────────────────────────
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft":                              "Information",
        "Microsoft.AspNetCore":                   "Warning",
        "Microsoft.EntityFrameworkCore.Database": "Information",
        "Microsoft.AspNetCore.SignalR":           "Debug"
      }
    }
  },

  // ── Database: SQL Server LocalDB for local dev ─────────────────────────────
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=NICEStandaloneRecording;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  // ── Recording storage: write recordings to the project folder (dev) ───────
  "RecordingStorage": {
    "RecordingsPath":  "C:\\Users\\ashok\\CascadeProjects\\Collaboration_standalone\\Recordings",
    "AttachmentsPath": "C:\\Users\\ashok\\CascadeProjects\\Collaboration_standalone\\Attachments"
  },

  // ── JWT: longer expiry for development convenience ─────────────────────────
  "Jwt": {
    "ExpiryMinutes":         1440,
    "ExpiryMinutesExternal": 1440
  },

  // ── Auth: no mocks needed — LOCAL_JWT works fine locally ──────────────────
  "AuthValidation": {
    "UseMock": false,
    "LocalJwt": {
      "ValidateExpiry": false
    }
  }
}
