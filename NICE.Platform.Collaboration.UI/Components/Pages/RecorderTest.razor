@page "/recorder-test"
@layout BlankLayout
@inject HttpClient Http
@inject IConfiguration Config
@inject IJSRuntime JS
@using System.Text.Json

@*
    TEST ONLY (Test C) — exercises the NICE.Platform.Collaboration.Recording package.
    Mints a StandAlone token, embeds <StandaloneRecorder/> (driven purely from JS),
    and calls window.niceScreenRecording.start({ token, collaborationId }).
    Remove this page (and the package reference / DI block) to decouple the Monitor UI.
*@

<div style="max-width:720px;margin:32px auto;font-family:system-ui;padding:0 16px">
    <h2>Recording package — test (Test C)</h2>

    <div style="background:#f5f5f5;border-radius:8px;padding:12px 16px;margin:12px 0;font-size:.85rem">
        <div><b>API base:</b> @_apiBase</div>
        <div><b>Application id:</b> @(_appId ?? "(resolving…)")</div>
        <div><b>Access token:</b> @(_token is null ? "(minting…)" : _token[..Math.Min(24, _token.Length)] + "…")</div>
        <div><b>Collaboration id (sent at start):</b> @_collabId</div>
        <div><b>JS bridge ready:</b> @_ready</div>
    </div>

    <div style="display:flex;gap:8px;margin:12px 0">
        <button @onclick="StartViaJs" disabled="@(!CanStart)"
                style="padding:8px 16px;border:0;border-radius:6px;background:#0a7;color:#fff;font-weight:600;cursor:pointer">
            ● Start via JavaScript
        </button>
        <button @onclick="StopViaJs"
                style="padding:8px 16px;border:0;border-radius:6px;background:#c33;color:#fff;font-weight:600;cursor:pointer">
            ■ Stop
        </button>
        <button @onclick="NewCollabId"
                style="padding:8px 16px;border:1px solid #ccc;border-radius:6px;background:#fff;cursor:pointer">
            New collaboration id
        </button>
    </div>

    <!-- The recorder component. Empty ChildContent hides its default UI; we drive it
         entirely through the JS global to exercise the real call path. -->
    <StandaloneRecorder Name="test" ApiBaseUrl="@_apiBase" ApplicationId="@_appId"
                        OnStarted="HandleStarted"
                        OnChunk="HandleChunk"
                        OnStopped="HandleStopped"
                        OnError="HandleError">
        <text></text>
    </StandaloneRecorder>

    <h4 style="margin-top:20px">Log</h4>
    <pre style="background:#111;color:#9f9;border-radius:8px;padding:12px;height:240px;overflow:auto;font-size:.8rem">@_log</pre>

    <p style="color:#666;font-size:.8rem">
        Record a few seconds, Stop, then open the newest file under your configured
        <code>LocalStorage:RecordingsPath</code> and confirm it plays in Windows Media Player.
    </p>
</div>

@code {
    private string  _apiBase = "";
    private string? _token;
    private string? _appId;
    private string  _collabId = Guid.NewGuid().ToString();
    private bool    _ready;
    private string  _log = "";

    private bool CanStart => _token is not null && !string.IsNullOrEmpty(_appId);

    protected override async Task OnInitializedAsync()
    {
        _apiBase = (Config["ApiBaseUrl"] ?? Http.BaseAddress?.ToString() ?? "").TrimEnd('/');
        try
        {
            // Mint a StandAlone token (auto-seeds the Readi app + user).
            var resp = await Http.PostAsync("api/v1/demo/mint-token?name=Test+Recorder&role=StandAlone", null);
            resp.EnsureSuccessStatusCode();
            using var doc = JsonDocument.Parse(await resp.Content.ReadAsStringAsync());
            _token = doc.RootElement.GetProperty("token").GetString();
            _appId = JwtClaim(_token!, "app");   // application GUID is the 'app' claim
            Log($"token minted; app={_appId}");
        }
        catch (Exception ex)
        {
            Log($"Failed to mint token: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // The component registers window.niceScreenRecording on its own first render.
        _ready = await JS.InvokeAsync<bool>("niceScreenRecording.isReady", "test");
        StateHasChanged();
    }

    private async Task StartViaJs()
    {
        try
        {
            await JS.InvokeVoidAsync("niceScreenRecording.start",
                new { token = _token, collaborationId = _collabId, name = "test" });
        }
        catch (Exception ex) { Log($"start() threw: {ex.Message}"); }
    }

    private async Task StopViaJs()
    {
        try { await JS.InvokeVoidAsync("niceScreenRecording.stop", "test"); }
        catch (Exception ex) { Log($"stop() threw: {ex.Message}"); }
    }

    private void NewCollabId() { _collabId = Guid.NewGuid().ToString(); Log($"new collaborationId: {_collabId}"); }

    // Recorder component event handlers
    private void HandleStarted(string mime) => Log($"started — mime: {mime}");
    private void HandleChunk(StandaloneRecorder.ChunkProgress c)
        => Log($"chunk #{c.Seq} — {c.ChunksSent} sent, {c.TotalBytes / 1024} KB");
    private void HandleStopped(StandaloneRecorder.RecordingResult r)
        => Log($"stopped — {r.ChunksSent} chunks, {r.TotalBytes / 1024} KB. Check the file in RecordingsPath.");
    private void HandleError(string err) => Log($"ERROR: {err}");

    private void Log(string msg)
    {
        _log = $"[{DateTime.Now:HH:mm:ss}] {msg}\n" + _log;
        StateHasChanged();
    }

    // Decode a JWT claim (no signature check) — used to read the 'app' application id.
    private static string? JwtClaim(string jwt, string name)
    {
        try
        {
            var parts = jwt.Split('.');
            if (parts.Length < 2) return null;
            var s = parts[1].Replace('-', '+').Replace('_', '/');
            s = s.PadRight(s.Length + (4 - s.Length % 4) % 4, '=');
            var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(s));
            using var doc = JsonDocument.Parse(json);
            return doc.RootElement.TryGetProperty(name, out var e) ? e.GetString() : null;
        }
        catch { return null; }
    }
}
