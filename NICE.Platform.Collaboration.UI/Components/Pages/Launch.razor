@page "/launch"
@layout BlankLayout
@inject IAuthService Auth
@inject NavigationManager Nav

@*
    Secure cross-tab launch target: /launch?code=<one-time opaque code>.
    Redeems the code (never a JWT) once for the session token (held in memory),
    replaces history so the code leaves the address bar, then opens the monitor.
    No default layout dependency — this page establishes its own session.
*@

<PageTitle>Opening monitor…</PageTitle>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#0b1020;color:#e8eaf0;font-family:system-ui,Segoe UI,sans-serif">
    <div style="text-align:center;max-width:460px;padding:24px">
        <div style="font-size:1.6rem;margin-bottom:10px">@(_failed ? "⚠️" : "🖥")</div>
        <div style="font-weight:600;margin-bottom:6px">@(_failed ? "Couldn't open the monitor" : "Opening the live monitor…")</div>
        <div style="color:#9aa4c4;font-size:.9rem">@_status</div>
    </div>
</div>

@code {
    private string _status = "Verifying your secure launch code…";
    private bool   _failed;

    protected override async Task OnInitializedAsync()
    {
        var code = ReadQuery("code");
        if (string.IsNullOrWhiteSpace(code))
        {
            Fail("No launch code was provided. Start from your application's ‘Open live monitor’ button.");
            return;
        }

        try
        {
            var result = await Auth.RedeemHandoffAsync(code);
            if (result.Success)
            {
                Nav.NavigateTo("/standalone-monitor", replace: true);
            }
            else
            {
                Fail(result.Error ?? "The launch code was invalid, expired, or already used.");
            }
        }
        catch (Exception ex)
        {
            Fail($"Launch error: {ex.Message}");
        }
    }

    private void Fail(string message)
    {
        _failed = true;
        _status = message;
        StateHasChanged();
    }

    // Minimal query parser — no external package needed in Blazor WASM.
    private string? ReadQuery(string key)
    {
        var q = new Uri(Nav.Uri).Query.TrimStart('?');
        if (string.IsNullOrEmpty(q)) return null;
        foreach (var pair in q.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = pair.Split('=', 2);
            if (kv.Length == 2 && string.Equals(Uri.UnescapeDataString(kv[0]), key, StringComparison.OrdinalIgnoreCase))
                return Uri.UnescapeDataString(kv[1]);
        }
        return null;
    }
}
